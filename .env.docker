APP_NAME=Property
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8088

# Внутри docker-сети Postgres доступен по имени сервиса db:5432
# (127.0.0.1:5433 — это публикуемый порт только для хоста).
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=property
DB_USERNAME=property
DB_PASSWORD=secret

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database
